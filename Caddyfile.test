{$DOMAIN_GW10000} {
	@blocked not remote_ip {$ALLOW_IPS}
	respond @blocked "Forbidden" 403

	tls /certs/openclaw-local.pem /certs/openclaw-local-key.pem
	reverse_proxy gateway-10000:18789
}

{$DOMAIN_GW20000} {
	@blocked not remote_ip {$ALLOW_IPS}
	respond @blocked "Forbidden" 403

	tls /certs/openclaw-local.pem /certs/openclaw-local-key.pem
	reverse_proxy gateway-20000:18789
}
