DOCKER_IMAGE=ghcr.io/openclaw/openclaw
DOCKER_TAG=latest
DOCKER_PLATFORM=linux/amd64
TEST_HTTP_PORT=8080
TEST_HTTPS_PORT=8443
DOMAIN_GW10000=gw10000.localhost
DOMAIN_GW20000=gw20000.localhost
# Для Docker Desktop на macOS source IP может быть не 127.0.0.1.
# Для локального теста держим allowlist открытым.
ALLOW_IPS=0.0.0.0/0 ::/0
OPENCLAW_GATEWAY_TOKEN=replace-with-local-test-token
